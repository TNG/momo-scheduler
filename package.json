{
  "name": "@tngtech/momo-scheduler",
  "version": "3.1.2",
  "description": "momo is a scheduler that persists jobs in mongodb",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TNG/momo-scheduler.git"
  },
  "keywords": [
    "delayed",
    "interval",
    "job",
    "jobs",
    "runner",
    "scheduler",
    "task",
    "recurrent"
  ],
  "private": false,
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.src.json",
    "format": "biome check --write",
    "lint": "biome ci",
    "clean": "npx rimraf dist",
    "test": "npm run test:checkTypes && vitest run",
    "test:checkTypes": "tsc -p tsconfig.test.json",
    "test:unit": "vitest run --exclude \"test/**/*.integration.*\"",
    "test:integration": "vitest run test/**/*.integration.*"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cron": "^4.4.0",
    "cron-parser": "^5.5.0",
    "lodash-es": "^4.18.1",
    "luxon": "^3.7.2",
    "neverthrow": "^8.2.0",
    "uuid": "^14.0.0"
  },
  "peerDependencies": {
    "mongodb": "5 || 6 || 7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@sinonjs/fake-timers": "15.4.0",
    "@types/lodash-es": "4.17.12",
    "@types/luxon": "3.7.2",
    "@types/node": "24.13.3",
    "@types/sinonjs__fake-timers": "15.0.1",
    "@types/uuid": "11.0.0",
    "mongodb-memory-server": "11.2.0",
    "pino": "10.3.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "vitest-mock-extended": "4.0.0"
  }
}
